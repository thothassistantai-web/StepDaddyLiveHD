# StepDaddyLiveHD v2.0 — Environment Configuration
# Copy this file to .env and adjust values as needed

# Server port
PORT=3000

# Public API URL (change to your domain/IP for network access)
API_URL=http://localhost:3000

# Proxy content segments through the server (TRUE/FALSE)
# Set to FALSE if clients can access stream hosts directly
PROXY_CONTENT=TRUE

# SOCKS5 proxy for DLHD requests (leave empty for direct)
# Format: user:password@proxy.example.com:1080
SOCKS5=

# Primary DaddyLive/DLHD base domain
# Change this if dlhd.pk is down; the app will try alternatives automatically
DLHD_BASE_URL=https://dlhd.pk
